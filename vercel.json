{
    "functions": {
        "api/**/*.py": {
            "excludeFiles": ["frontend/**", "test.db"]
        }
    },
    "buildCommand": "cd frontend && bash build.sh",
    "outputDirectory": "frontend/build/web",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/api",
            "destination": "/api/index"
        },
        {
            "source": "/webhook/(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}