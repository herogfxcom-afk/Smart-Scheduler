{
    "functions": {
        "api/index.py": {
            "runtime": "vercel-python@1.3.1"
        }
    },
    "buildCommand": "cd frontend && bash build.sh",
    "outputDirectory": "frontend/build/web",
    "rewrites": [
        {
            "source": "/api(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/webhook(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}