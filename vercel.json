{
    "functions": {
        "api/index.py": {
            "excludeFiles": "frontend/**"
        }
    },
    "buildCommand": "cd frontend && bash build.sh",
    "outputDirectory": "frontend/build/web",
    "rewrites": [
        {
            "source": "/(api|auth|webhook|calendar|groups|meeting|users|cors-debug)(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/((?!api|auth|webhook|calendar|groups|meeting|users|cors-debug).*)",
            "destination": "/index.html"
        }
    ]
}