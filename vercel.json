{
    "functions": {
        "api/**/*.py": {
            "excludeFiles": "frontend/**"
        }
    },
    "buildCommand": "cd frontend && bash build.sh",
    "outputDirectory": "frontend/build/web",
    "rewrites": [
        {
            "source": "/((?!api|webhook).*)",
            "destination": "/index.html"
        }
    ]
}