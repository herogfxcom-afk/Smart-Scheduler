{
    "functions": {
        "api/index.py": {
            "excludeFiles": ["frontend/**", "venv/**", ".venv/**", "node_modules/**", "alembic/**", ".git/**"]
        }
    },
    "buildCommand": "cd frontend && bash build.sh && cd .. && cp -r frontend/build/web public && rm -rf frontend venv .venv node_modules alembic .git",
    "outputDirectory": "public",
    "rewrites": [
        {
            "source": "/(api|auth|webhook|calendar|groups|meeting|users|cors-debug)(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/((?!api|auth|webhook|calendar|groups|meeting|users|cors-debug).*)",
            "destination": "/index.html"
        }
    ]
}