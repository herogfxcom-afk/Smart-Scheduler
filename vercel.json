{
    "functions": {
        "api/*.py": {
            "excludeFiles": "frontend/**"
        }
    },
    "buildCommand": "cd frontend && bash build.sh && cd .. && cp -r frontend/build/web public && rm -rf frontend",
    "outputDirectory": "public",
    "rewrites": [
        {
            "source": "/(api|auth|webhook|calendar|groups|meeting|users|cors-debug)(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/((?!api|auth|webhook|calendar|groups|meeting|users|cors-debug).*)",
            "destination": "/index.html"
        }
    ]
}