{
    "version": 2,
    "routes": [
        {
            "src": "/flutter_bootstrap.js",
            "dest": "/flutter_bootstrap.js"
        },
        {
            "src": "/flutter.js",
            "dest": "/flutter.js"
        },
        {
            "src": "/main.dart.js",
            "dest": "/main.dart.js"
        },
        {
            "src": "/flutter_service_worker.js",
            "dest": "/flutter_service_worker.js"
        },
        {
            "src": "/canvaskit/(.*)",
            "dest": "/canvaskit/$1"
        },
        {
            "src": "/assets/(.*)",
            "headers": {
                "cache-control": "public,max-age=31536000,immutable"
            },
            "dest": "/assets/$1"
        },
        {
            "src": "/icons/(.*)",
            "dest": "/icons/$1"
        },
        {
            "src": "/favicon.png",
            "dest": "/favicon.png"
        },
        {
            "src": "/manifest.json",
            "dest": "/manifest.json"
        },
        {
            "src": "/version.json",
            "dest": "/version.json"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}